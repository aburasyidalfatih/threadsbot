<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profil - ThreadsBot</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/mobile-improvements.css">
</head>
<body>
  <!-- Sidebar -->
  <nav class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="logo">
        <span class="logo-icon">🤖</span>
        <span class="logo-text">ThreadsBot</span>
      </div>
    </div>
    <ul class="nav-menu">
      <li class="nav-item">
        <a href="/" class="nav-link" id="nav-dashboard">
          <span class="nav-icon">📊</span>
          <span class="nav-label">Dashboard</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/accounts" class="nav-link" id="nav-accounts">
          <span class="nav-icon">👥</span>
          <span class="nav-label">Akun</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/posts/create" class="nav-link" id="nav-create-post">
          <span class="nav-icon">✍️</span>
          <span class="nav-label">Buat Post</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/queue" class="nav-link" id="nav-queue">
          <span class="nav-icon">📝</span>
          <span class="nav-label">Content Queue</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/autopilot" class="nav-link" id="nav-autopilot">
          <span class="nav-icon">🚀</span>
          <span class="nav-label">Auto Pilot</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/affiliate" class="nav-link" id="nav-affiliate">
          <span class="nav-icon">🛍️</span>
          <span class="nav-label">Affiliate Product</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/posts/history" class="nav-link" id="nav-history">
          <span class="nav-icon">📋</span>
          <span class="nav-label">Riwayat</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/settings" class="nav-link" id="nav-settings">
          <span class="nav-icon">⚙️</span>
          <span class="nav-label">Pengaturan</span>
        </a>
      </li>
      <% if (user) { %>
        <li class="nav-item">
          <a href="/profile" class="nav-link active" id="nav-profile">
            <span class="nav-icon">👤</span>
            <span class="nav-label">Profil</span>
          </a>
        </li>
      <% } %>
    </ul>
    <div class="sidebar-footer">
      <div class="app-version">v1.0.0</div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="main-content">
    <div class="topbar">
      <button class="menu-toggle" id="menu-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>
      <h1 class="page-title">Profil Pengguna</h1>
      <div class="topbar-right">
        <% if (user) { %>
          <div class="user-header">
            <span class="user-greeting">Halo, <strong><%= user.name %></strong></span>
            <a href="/logout" class="logout-btn">
              <span class="logout-icon">🚪</span>
              <span class="logout-text">Logout</span>
            </a>
          </div>
        <% } %>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-error" style="margin: 20px 32px 0;">⚠️ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success" style="margin: 20px 32px 0;">✅ <%= success %></div>
    <% } %>

    <div class="content-area">
      <div class="profile-grid">
        <!-- Profile Info Card -->
        <div class="card-container">
          <div class="card-header">
            <h3 class="card-title">Informasi Profil</h3>
          </div>
          <div class="card-content">
            <div class="profile-avatar-section">
              <div class="profile-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
            </div>
            <form method="POST" action="/profile/update" class="form-group-container">
              <div class="form-group">
                <label for="name">Nama Lengkap</label>
                <input type="text" id="name" name="name" value="<%= user.name %>" required>
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="<%= user.email %>" required>
              </div>
              <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
            </form>
          </div>
        </div>

        <!-- Change Password Card -->
        <div class="card-container">
          <div class="card-header">
            <h3 class="card-title">Ubah Password</h3>
          </div>
          <div class="card-content">
            <form method="POST" action="/profile/change-password" class="form-group-container">
              <div class="form-group">
                <label for="old_password">Password Lama</label>
                <input type="password" id="old_password" name="old_password" required>
              </div>
              <div class="form-group">
                <label for="new_password">Password Baru</label>
                <input type="password" id="new_password" name="new_password" required>
              </div>
              <div class="form-group">
                <label for="new_password_confirm">Konfirmasi Password Baru</label>
                <input type="password" id="new_password_confirm" name="new_password_confirm" required>
              </div>
              <button type="submit" class="btn btn-primary">Ubah Password</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>

  <style>
    .profile-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
      gap: 24px;
    }

    .card-container {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      overflow: hidden;
      transition: var(--transition);
    }

    .card-container:hover {
      border-color: var(--accent-primary);
      box-shadow: 0 0 20px var(--accent-primary-glow);
    }

    .card-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--border-color);
      background: var(--bg-tertiary);
    }

    .card-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
    }

    .card-content {
      padding: 24px;
    }

    .profile-avatar-section {
      text-align: center;
      margin-bottom: 24px;
    }

    .profile-avatar {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent-primary), var(--accent-affiliate));
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      font-weight: 700;
      margin: 0 auto;
      box-shadow: 0 4px 12px var(--accent-primary-glow);
    }

    .form-group-container {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-group label {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .form-group input {
      padding: 10px 12px;
      background: var(--bg-input);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-sm);
      color: var(--text-primary);
      font-size: 13px;
      font-family: 'Inter', sans-serif;
      transition: var(--transition);
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--accent-primary);
      box-shadow: 0 0 0 3px var(--accent-primary-glow);
    }

    .btn {
      padding: 10px 16px;
      border: none;
      border-radius: var(--radius-sm);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      font-family: 'Inter', sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent-primary), var(--accent-affiliate));
      color: white;
      box-shadow: 0 4px 12px var(--accent-primary-glow);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px var(--accent-primary-glow);
    }

    .alert {
      padding: 12px 16px;
      border-radius: var(--radius-sm);
      margin-bottom: 20px;
      font-size: 13px;
      border: 1px solid;
    }

    .alert-error {
      background: rgba(255, 77, 106, 0.1);
      color: var(--accent-danger);
      border-color: var(--accent-danger);
    }

    .alert-success {
      background: rgba(45, 212, 160, 0.1);
      color: var(--accent-success);
      border-color: var(--accent-success);
    }

    @media (max-width: 768px) {
      .profile-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script src="/js/app.js"></script>
</body>
</html>
