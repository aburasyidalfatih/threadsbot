<%- include('layout', { body: `
<div class="card" id="affiliate-account-card">
  <div class="card-header">
    <h3>👤 Pilih Akun & Pengaturan</h3>
  </div>
  <div class="card-body">
    <div class="form-row">
      <div class="form-group">
        <label for="aff-account">Akun Threads</label>
        <select id="aff-account" required>
          <option value="">— Pilih Akun —</option>
          ${accounts.map(acc => '<option value="' + acc.id + '">@' + acc.username + '</option>').join('')}
        </select>
        ${accounts.length === 0 ? '<small class="form-hint">Belum ada akun aktif. <a href="/accounts">Tambah akun</a> terlebih dahulu.</small>' : ''}
      </div>
      <div class="form-group">
        <label for="aff-comment-count">Jumlah Komentar Lanjutan: <span id="aff-count-display">${defaultCommentCount}</span></label>
        <input type="range" id="aff-comment-count" min="2" max="7" value="${defaultCommentCount}" oninput="document.getElementById('aff-count-display').textContent=this.value">
      </div>
    </div>
  </div>
</div>

<div class="two-column">
  <div class="card" id="add-product-card">
    <div class="card-header">
      <h3>🛍️ Tambah Produk Affiliate</h3>
    </div>
    <div class="card-body">
      <form action="/affiliate/product/add" method="POST" class="form-stack">
        <div class="form-group">
          <label for="product_name">Nama Produk</label>
          <input type="text" id="product_name" name="product_name" placeholder="Contoh: Headphone Bluetooth TWS" required>
        </div>
        <div class="form-group">
          <label for="description">Deskripsi Produk</label>
          <textarea id="description" name="description" rows="3" placeholder="Deskripsi singkat produk, fitur utama, harga..." required></textarea>
        </div>
        <div class="form-group">
          <label for="affiliate_link">Link URL Affiliate</label>
          <input type="url" id="affiliate_link" name="affiliate_link" placeholder="https://..." required>
        </div>
        <div class="btn-right-container">
          <button type="submit" class="btn btn-primary" id="btn-add-product">Tambah Produk</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card" id="products-list-card">
    <div class="card-header">
      <h3>📦 Daftar Produk (${products.length})</h3>
    </div>
    <div class="card-body">
      ${products.length === 0 ? '<p class="empty-state">Belum ada produk. Tambahkan di form sebelah.</p>' : ''}
      <div class="product-list">
        ${products.map(p => '<div class="product-item">' +
          '<div class="product-info">' +
            '<div class="product-name">' + p.product_name + '</div>' +
            '<div class="product-desc">' + (p.description || '').substring(0, 80) + '...</div>' +
            '<div class="product-link"><a href="' + p.affiliate_link + '" target="_blank">' + p.affiliate_link.substring(0, 40) + '...</a></div>' +
          '</div>' +
          '<div class="product-actions">' +
            '<button class="btn btn-sm btn-primary" onclick="generateAffiliate(' + p.id + ')">🤖 Generate Post</button>' +
            '<form action="/affiliate/product/delete/' + p.id + '" method="POST" style="display:inline"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm(\'Hapus produk ini?\')">🗑️</button></form>' +
          '</div>' +
        '</div>').join('')}
      </div>
    </div>
  </div>
</div>

<div class="card" id="affiliate-preview-card" style="display:none">
  <div class="card-header">
    <h3>👁️ Preview Konten Promosi</h3>
    <span class="badge badge-affiliate" id="aff-product-badge"></span>
  </div>
  <div class="card-body">
    <div class="thread-preview" id="aff-thread-preview"></div>
  </div>
  <div class="card-footer" style="justify-content: flex-end;">
    <button class="btn btn-success btn-glow" id="btn-aff-post" onclick="postAffiliate()">
      <span class="btn-loader" id="aff-post-loader" style="display:none"></span>
      🚀 Post ke Threads
    </button>
  </div>
</div>

<div id="aff-result" class="alert" style="display:none"></div>
` }) %>

<script>
let selectedProductId = null;
let affContent = null;
let affProductName = '';

async function generateAffiliate(productId) {
  selectedProductId = productId;

  const accountId = document.getElementById('aff-account').value;
  if (!accountId) {
    alert('Pilih akun Threads terlebih dahulu di bagian atas!');
    document.getElementById('aff-account').focus();
    document.getElementById('affiliate-account-card').scrollIntoView({ behavior: 'smooth' });
    return;
  }

  const btn = event.target;
  btn.disabled = true;
  btn.textContent = '⏳ Generating...';

  try {
    const res = await fetch('/affiliate/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        product_id: productId,
        comment_count: document.getElementById('aff-comment-count').value
      })
    });
    const data = await res.json();
    if (!data.success) throw new Error(data.error);

    affContent = data.content;
    affProductName = data.product.product_name;
    document.getElementById('aff-product-badge').textContent = affProductName;

    // Render preview
    let html = '<div class="thread-main"><div class="thread-avatar">📝</div><div class="thread-content"><div class="thread-author">@username</div><div class="thread-text">' + data.content.main_post + '</div></div></div>';
    data.content.comments.forEach((c, i) => {
      html += '<div class="thread-reply"><div class="thread-line"></div><div class="thread-avatar">💬</div><div class="thread-content"><div class="thread-author">@username <span class="reply-badge">Reply ' + (i+1) + '</span></div><div class="thread-text">' + c + '</div></div></div>';
    });
    document.getElementById('aff-thread-preview').innerHTML = html;

    document.getElementById('affiliate-preview-card').style.display = 'block';
    document.getElementById('affiliate-preview-card').scrollIntoView({ behavior: 'smooth' });
  } catch (err) {
    alert('Error: ' + err.message);
  } finally {
    btn.disabled = false;
    btn.textContent = '🤖 Generate Post';
  }
}

async function postAffiliate() {
  if (!affContent) return;
  const accountId = document.getElementById('aff-account').value;
  if (!accountId) return alert('Pilih akun terlebih dahulu');
  if (!confirm('Post promosi ini ke Threads?')) return;

  const btn = document.getElementById('btn-aff-post');
  btn.disabled = true;

  try {
    const res = await fetch('/affiliate/post', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        account_id: accountId,
        product_name: affProductName,
        content_main: affContent.main_post,
        content_comments: JSON.stringify(affContent.comments),
        comment_count: affContent.comments.length
      })
    });
    const result = await res.json();
    const el = document.getElementById('aff-result');
    el.style.display = 'block';
    el.className = 'alert ' + (result.success ? 'alert-success' : 'alert-error');
    el.textContent = result.success ? '✅ Konten promosi sedang diposting!' : '⚠️ ' + result.error;
    el.scrollIntoView({ behavior: 'smooth' });
  } catch (err) {
    alert('Error: ' + err.message);
  } finally {
    btn.disabled = false;
  }
}
</script>
